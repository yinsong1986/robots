{
    "providers": {
        "mock": {
            "module": "strands_robots.policies.mock",
            "class": "MockPolicy",
            "description": "Sinusoidal test actions (no deps)",
            "requires": [],
            "config_keys": [],
            "defaults": {},
            "shorthands": [
                "mock",
                "random",
                "test"
            ]
        },
        "groot": {
            "module": "strands_robots.policies.groot",
            "class": "Gr00tPolicy",
            "description": "NVIDIA GR00T N1.5/N1.6 via ZMQ",
            "requires": [
                "port"
            ],
            "config_keys": [
                "port",
                "host",
                "data_config"
            ],
            "defaults": {
                "host": "localhost"
            },
            "shorthands": [
                "groot"
            ],
            "url_patterns": [
                "^zmq://"
            ],
            "hf_orgs": [
                "nvidia"
            ],
            "model_id_overrides": [
                "nvidia/gr00t",
                "nvidia/groot"
            ]
        },
        "lerobot_local": {
            "module": "strands_robots.policies.lerobot_local",
            "class": "LerobotLocalPolicy",
            "description": "Direct HuggingFace inference (no server)",
            "requires": [],
            "config_keys": [
                "pretrained_name_or_path",
                "policy_type",
                "device",
                "actions_per_step",
                "norm_tag",
                "image_keys",
                "inference_action_mode",
                "embodiment"
            ],
            "defaults": {},
            "aliases": [
                "lerobot"
            ],
            "hf_orgs": [
                "lerobot",
                "allenai"
            ],
            "is_hf_default": true
        },
        "cosmos3": {
            "module": "strands_robots.policies.cosmos3",
            "class": "Cosmos3Policy",
            "description": "NVIDIA Cosmos 3 omnimodal VLA policy (DROID/UMI/AV/bridge) via Cosmos Framework",
            "requires": [],
            "config_keys": [
                "embodiment",
                "host",
                "port",
                "action_space",
                "observation_mapping",
                "action_mapping",
                "robot",
                "prompt",
                "api_key"
            ],
            "defaults": {
                "host": "localhost",
                "port": 8000,
                "embodiment": "droid"
            },
            "shorthands": [
                "cosmos3",
                "c3"
            ],
            "url_patterns": [
                "^cosmos3://"
            ],
            "hf_orgs": [],
            "model_id_overrides": [
                "nvidia/cosmos3",
                "nvidia/cosmos3-nano-policy"
            ]
        },
        "moveit2": {
            "module": "strands_robots.policies.moveit2",
            "class": "MoveIt2Policy",
            "description": "MoveIt2 motion planning via ZMQ sidecar",
            "requires": [
                "port"
            ],
            "config_keys": [
                "host",
                "port",
                "planning_group",
                "timeout_ms",
                "api_token"
            ],
            "defaults": {
                "host": "127.0.0.1",
                "port": 5556,
                "planning_group": "arm"
            },
            "shorthands": [
                "moveit2"
            ],
            "aliases": [
                "moveit"
            ]
        },
        "curobo": {
            "module": "strands_robots.policies.curobo",
            "class": "CuroboPolicy",
            "description": "NVIDIA cuRobo collision-aware motion planning (in-process, CUDA)",
            "requires": [],
            "config_keys": [
                "robot_config",
                "world_config",
                "action_horizon",
                "tensor_args",
                "motion_gen_kwargs"
            ],
            "defaults": {
                "action_horizon": 16
            },
            "shorthands": [
                "curobo"
            ],
            "aliases": [
                "cumotion"
            ]
        }
    }
}
